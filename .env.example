# LLM Provider: openai | anthropic | ollama | openrouter
LLM_PROVIDER=openai
# Embeddings: openai | local (local uses all-MiniLM-L6-v2, free)
EMBEDDINGS_PROVIDER=openai
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OpenRouter (OpenAI-compatible proxy for many models)
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=openai/gpt-4o
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://your-app.com
# OPENROUTER_SITE_NAME=Telecom Ticket Analyzer
# OPENROUTER_EMBEDDINGS_MODEL=text-embedding-3-small

# S3-compatible storage (Coolify / MinIO / AWS S3)
S3_ENDPOINT_URL=http://your-coolify-s3-url:9000
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=telecom-pdfs
S3_REGION=us-east-1

# ChromaDB persistence path
CHROMA_DB_PATH=data/chroma_db

# Analyses database path (SQLite)
ANALYSES_DB_PATH=data/analyses.db
